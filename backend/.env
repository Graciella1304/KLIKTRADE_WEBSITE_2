PORT=3001
JWT_SECRET=kliktrade_rwanda_2024_very_long_and_secure_secret_key_change_in_production

# Google OAuth — get from https://console.cloud.google.com
# 1. Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# 2. Application type: Web application
# 3. Authorized JavaScript origins: http://localhost:5000
# 4. Copy Client ID and paste below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Apple Sign-In — requires Apple Developer account ($99/yr)
# https://developer.apple.com/account/resources/identifiers
APPLE_CLIENT_ID=your_apple_service_id_here
APPLE_TEAM_ID=your_apple_team_id_here
APPLE_KEY_ID=your_apple_key_id_here
